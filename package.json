{
  "name": "feedforge",
  "version": "0.1.18",
  "private": true,
  "description": "Desktop toolkit for preparing FeedBack-ready song packages.",
  "author": "FeedForge Contributors",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "converter:pack": "python -m PyInstaller --noconfirm --clean psarc2feedpak.spec",
    "electron:pack": "npm run build && electron-builder --win",
    "release": "npm run converter:pack && npm run electron:pack",
    "lint:ui": "vite build"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.feedforge.app",
    "productName": "FeedForge",
    "files": [
      "desktop-dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/psarc2feedpak",
        "to": "bin/psarc2feedpak"
      },
      {
        "from": "src",
        "to": "demucs-server/src",
        "filter": [
          "feedback_converter/**/*.py",
          "feedback_converter/data/feedpak_schemas/*.json"
        ]
      },
      {
        "from": "pyproject.toml",
        "to": "demucs-server/pyproject.toml"
      },
      {
        "from": "tools/start-demucs-server.ps1",
        "to": "demucs-server/start-demucs-server.ps1"
      },
      {
        "from": "assets/tone-equipment",
        "to": "tone-equipment"
      },
      {
        "from": "src/feedback_converter/data/equipment.json",
        "to": "tone-equipment/equipment.json"
      },
      {
        "from": "src/feedback_converter/data/feedback_equipment.json",
        "to": "tone-equipment/feedback_equipment.json"
      }
    ],
    "directories": {
      "output": "release"
    },
    "compression": "maximum",
    "electronLanguages": [
      "en-US"
    ],
    "win": {
      "icon": "assets/feedforge.ico",
      "target": [
        "portable"
      ],
      "signExecutable": false
    },
    "portable": {
      "unpackDirName": "FeedForge"
    }
  }
}
